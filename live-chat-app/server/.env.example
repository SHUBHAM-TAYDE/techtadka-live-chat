# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── PostgreSQL (Utho Managed DB) ──────────────────────────────────────────────
DB_HOST=your-utho-managed-db-host
DB_PORT=5432
DB_NAME=livechat
DB_USER=livechat_user
DB_PASSWORD=your_strong_db_password
DB_SSL=true

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=your-redis-vm-private-ip
REDIS_PORT=6379
REDIS_PASSWORD=your_strong_redis_password

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
